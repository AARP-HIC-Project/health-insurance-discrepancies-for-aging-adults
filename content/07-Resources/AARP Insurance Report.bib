  keywords = {ACA,Access to care,Affordable Care Act,Emigrants and Immigrants,Health care reform,Health insurance,Health Services Accessibility,Healthcare Disparities,Humans,Immigrants,Insurance Coverage,Insurance Health,Medically Uninsured,Office Visits,Patient Protection and Affordable Care Act,Socioeconomic Factors,United States},
