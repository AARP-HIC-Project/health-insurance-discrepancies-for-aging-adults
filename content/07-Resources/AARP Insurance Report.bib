@article{zambranaImprovingHealthInsurance2004,
  title = {Improving Health Insurance Coverage for {{Latino}} Children: A Review of Barriers, Challenges and {{State}} Strategies},
  shorttitle = {Improving Health Insurance Coverage for {{Latino}} Children},
  author = {Zambrana, Ruth E. and {Carter-Pokras}, Olivia},
