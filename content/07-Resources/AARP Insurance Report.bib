@article{hasstedtImmigrantWomensAccess2018,
  title = {Immigrant {{Women}}'s {{Access}} to {{Sexual}} and {{Reproductive Health Coverage}} and {{Care}} in the {{United States}}},
  author = {Hasstedt, Kinsey and Desai, Sheila and {Ansari-Thomas}, Zhora},
  year = {2018},
  month = nov,
  journal = {Issue Brief (Commonwealth Fund)},
  volume = {2018},
  pages = {1--10},
  issn = {1558-6847},
  abstract = {ISSUE: Immigrant women of reproductive age in the U.S. face significant challenges obtaining comprehensive and affordable health insurance coverage and care--including sexual and reproductive health services--compared with U.S.-born women, because of myriad policy and systemic factors. GOALS: Synthesize recent evidence on immigrant women's access to sexual and reproductive health coverage and care and provide recommendations for policymaking and research. METHODS: A rapid literature review to identify and summarize evidence from peer-reviewed and select grey literature published since 2011 on health insurance coverage and sexual and reproductive health care services use among immigrant women in the U.S. Where available, evidence is compared to U.S.-born women. FINDINGS AND CONCLUSIONS: Immigrant women are less likely to have coverage and use sexual and reproductive health services than U.S.-born women, which may increase their risk of negative outcomes. Federal and state policymakers could take actions to advance immigrant women's sexual and reproductive health, including expanding eligibility for coverage and shoring up the nation's health care safety net. Further research is needed to understand the needs, use of services, and outcomes of immigrant women, as well as the factors that contribute to differences between immigrant and U.S.-born women, and among groups of immigrant women.},
  langid = {english},
  pmid = {30458586},
  keywords = {Emigrants and Immigrants,Facilities and Services Utilization,Female,Health Services Accessibility,Healthcare Disparities,Humans,Insurance Coverage,Medicaid,Medically Uninsured,Pregnancy,Reproductive Health Services,Safety-net Providers,United States,Women,Women's Health Services}
