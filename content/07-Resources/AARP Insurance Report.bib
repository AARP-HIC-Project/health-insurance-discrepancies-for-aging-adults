@article{montezEmploymentMarriageInequality2009,
  title = {Employment, {{Marriage}}, and {{Inequality}} in {{Health Insurance}} for {{Mexican-Origin Women}}{$\ast$}},
  author = {Montez, Jennifer Karas and Angel, Jacqueline L. and Angel, Ronald J.},
  year = {2009},
