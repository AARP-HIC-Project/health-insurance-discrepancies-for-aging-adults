@article{teruelcamargoAdvancingAgingResearch2024,
  title = {Advancing {{Aging Research Through}} a {{Health Disparities Perspective}}},
  author = {Teruel Camargo, Juliana and Smith, Jessica T and Rodriquez, Erik J and {P{\'e}rez-Stable}, Eliseo J},
  editor = {Lipsitz, Lewis A},
