@article{angierRacialEthnicDisparities2019,
  title = {Racial/{{Ethnic Disparities}} in {{Health Insurance}} and {{Differences}} in {{Visit Type}} for a {{Population}} of {{Patients}} with {{Diabetes}} after {{Medicaid Expansion}}},
  author = {Angier, Heather and {Ezekiel-Herrera}, David and Marino, Miguel and Hoopes, Megan and Jacobs, Elizabeth A. and DeVoe, Jennifer E. and Huguet, Nathalie},
