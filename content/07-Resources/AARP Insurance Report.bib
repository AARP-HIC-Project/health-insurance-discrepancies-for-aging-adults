@article{searsTrendsDisproportionateBurden2012,
  title = {Trends in the Disproportionate Burden of Work-Related Traumatic Injuries Sustained by {{Latinos}}},
  author = {Sears, Jeanne M. and Bowman, Stephen M. and Silverstein, Barbara A.},
  year = {2012},
