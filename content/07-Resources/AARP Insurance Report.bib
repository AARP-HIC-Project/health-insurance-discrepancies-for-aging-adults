@article{maldonado-pueblaPharmacoequityAllergyImmunologyDisparities2024,
  title = {Pharmacoequity in {{Allergy-Immunology}}: {{Disparities}} in {{Access}} to {{Medications}} for {{Allergic Diseases}} and {{Proposed Solutions}} in the {{United States}} and {{Globally}}},
  shorttitle = {Pharmacoequity in {{Allergy-Immunology}}},
