@article{markowitzRelationshipPatientExperience2022,
  title = {Relationship between {{Patient Experience Scores}} and {{Health Insurance}}},
  author = {Markowitz, Walter and Kausar, Khadeja and Coffield, Edward},
  year = {2022},
