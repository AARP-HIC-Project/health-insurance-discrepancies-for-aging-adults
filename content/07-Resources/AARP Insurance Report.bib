@article{joudehLittleRedFlags2021,
  title = {``{{Little Red Flags}}'': {{Barriers}} to {{Accessing Health Care}} as a {{Sexual}} or {{Gender Minority Individual}} in the {{Rural Southern United States}}---{{A Qualitative Intersectional Approach}}},
  shorttitle = {``{{Little Red Flags}}''},
  author = {Joudeh, Layla and Harris, Orlando O. and Johnstone, Ethan and {Heavner-Sullivan}, Smith and Propst, Shantara K.},
  year = {2021},
