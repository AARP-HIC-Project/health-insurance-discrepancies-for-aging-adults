@article{linEffectsMedicaidExpansion2021,
  title = {Effects of Medicaid Expansion on Poverty Disparities in Health Insurance Coverage},
  author = {Lin, Yilu and Monnette, Alisha and Shi, Lizheng},
  year = {2021},
  month = jul,
  journal = {International Journal for Equity in Health},
  volume = {20},
  number = {1},
  pages = {171},
  issn = {1475-9276},
  doi = {10.1186/s12939-021-01486-3},
  abstract = {BACKGROUND: More than 30 states have either expanded Medicaid or are actively considering expansion. The coverage gains from this policy are well documented, however, the impacts of its increasing coverage on poverty disparity are unclear at the national level. METHOD: American Community Survey (2012-2018) was used to examine the effects of Medicaid expansion on poverty disparity in insurance coverage for nonelderly adults in the United States. Differences-in-differences-in-differences design was used to analyze trends in uninsured rates by poverty levels: (1)\,{$<$}\,138\,\%, (2) 138-400\,\% and (3)\,{$>$}\,400\,\% federal poverty level (FPL). RESULTS: Compared with uninsured rates in 2012, uninsured rates in 2018 decreased by 10.75\,\%, 6.42\,\%, and 1.11\,\% for {$<$}\,138\,\%, 138-400\,\%, and {$>$}\,400\,\% FPL, respectively. From 2012 to 2018, {$>$}\,400\,\% FPL group continuously had the lowest uninsured rate and {$<$}\,138\,\% FPL group had the highest uninsured rate. Compared with {$\geq$}\,138\,\% FPL groups, there was a 2.54\,\% reduction in uninsured risk after Medicaid expansion among {$<$}\,138\,\% FPL group in Medicaid expansion states versus control states. After eliminating the impact of the ACA market exchange premium subsidy, 3.18\,\% decrease was estimated. CONCLUSION: Poverty disparity in uninsured rates improved with Medicaid expansion. However, {$<$}\,138\,\% FPL population are still at a higher risk for being uninsured.},
  langid = {english},
  pmcid = {PMC8314606},
  pmid = {34311757},
  keywords = {Effects of ACA,Employer-based insurance issues,Health equity,income-based discrepancies,Insurance coverage,Insurance Coverage,Insurance Health,Medicaid,Medicaid expansion,Poverty,Poverty disparity,Reviewed},
  file = {/Users/dbd/Zotero/storage/V9YQ6DHE/Lin et al_2021_Effects of medicaid expansion on poverty disparities in health insurance.pdf}
}

@techreport{livermoreHealthInsuranceHealth2009,
